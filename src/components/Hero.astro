---
interface Props {
  name: string;
  title: string;
  tagline?: string;
}
const { name, title, tagline } = Astro.props as Props;
import SocialLinks from './SocialLinks.astro';
---

<header class="hero reveal" aria-label="Introduction">
  <div class="hero-row">
    <img src="/profile.png" alt="Najib Ninaba" class="avatar" width="280" height="280" />
    <div class="hero-text">
      <h1 class="name">{name}</h1>
      <p class="role">{title}</p>
      {tagline && <p class="tagline">{tagline}</p>}
      <SocialLinks variant="hero" />
    </div>
  </div>
</header>

<style>
  .hero {
    max-width: var(--maxw);
    margin: clamp(2rem, 10vh, 8rem) auto 3rem;
    padding: 0 1rem;
  }

  .hero-row {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 2rem;
  }

  .avatar {
    width: 140px;
    height: auto;
    object-fit: cover;
    border-radius: 24px;
    flex-shrink: 0;
  }

  .hero-text {
    min-width: 0;
  }

  .hero-text :global(.social-links) {
    margin: 0.75rem 0 0;
  }

  .name {
    letter-spacing: -0.02em;
    margin: 0;
    font-weight: 700;
  }

  .role {
    margin: 0.25rem 0 0;
    font-size: clamp(1rem, 2.25vw, 1.15rem);
    color: var(--fg);
    opacity: 0.9;
  }

  .tagline {
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    color: var(--muted);
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .hero-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>